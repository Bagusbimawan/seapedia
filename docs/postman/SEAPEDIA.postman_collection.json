{
  "info": {
    "name": "SEAPEDIA API",
    "description": "COMPFEST 18 — Multi-Role Marketplace API\n\nImport OpenAPI: backend/docs/swagger.json\nBase URL: http://localhost:8080/api/v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Buyer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@seapedia.com\",\n  \"password\": \"buyer123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Switch Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"BUYER\"\n}"
            },
            "url": "{{baseUrl}}/auth/switch-role"
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products?page=1&limit=10"
          }
        },
        {
          "name": "List Reviews",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reviews"
          }
        }
      ]
    },
    {
      "name": "Buyer",
      "item": [
        {
          "name": "Get Wallet",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/buyer/wallet"
          }
        },
        {
          "name": "Validate Discount",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"DISC20\",\n  \"subtotal\": 100000\n}"
            },
            "url": "{{baseUrl}}/buyer/discount/validate"
          }
        }
      ]
    }
  ]
}
