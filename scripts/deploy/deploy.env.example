# =============================================================================
# SEAPEDIA — Production config (Amazon Linux EC2)
# Copy: cp scripts/deploy/deploy.env.example scripts/deploy/deploy.env
# =============================================================================

# --- Domain ---
FRONTEND_DOMAIN=seapedia.fe.bagusbimawan.com
API_DOMAIN=seapedia.be.bagusbimawan.com
LETSENCRYPT_EMAIL=admin@bagusbimawan.com

# --- API URL untuk build frontend ---
NEXT_PUBLIC_API_URL=https://seapedia.be.bagusbimawan.com/api/v1

# --- Database EKSTERNAL (RDS / managed — isi kredensial DB kamu) ---
# Password boleh mengandung ) $ ! — tidak perlu kutip, atau pakai '...' jika mau
DB_HOST=your-db.xxxxx.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=seapedia
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=seapedia_db
DB_SSLMODE=require

# --- Backend ---
# JWT_SECRET: min 32 karakter; karakter spesial ( ) $ ! aman tanpa kutip
JWT_SECRET=CHANGE_ME_MIN_32_RANDOM_CHARACTERS
JWT_EXPIRY=24h
ENV=production
CORS_ORIGINS=https://seapedia.fe.bagusbimawan.com

# --- Path project di server EC2 ---
APP_DIR=/opt/seapedia

# --- User systemd ---
APP_USER=seapedia
